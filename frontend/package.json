{
  "name": "frontend",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "package": "cd ../backend && npm run build && cd ../frontend && electron-vite build && electron-builder"
  },
  "main": "out/main/index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "iq.iraqhms.app",
    "productName": "Iraq HMS",
    "extraResources": [
      { "from": "../backend/dist", "to": "backend/dist" },
      { "from": "../backend/node_modules", "to": "backend/node_modules" },
      { "from": "../backend/package.json", "to": "backend/package.json" },
      { "from": "../backend/prisma", "to": "backend/prisma" },
      { "from": "../backend/.env", "to": "backend/.env" }
    ]
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "antd": "^6.5.0",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6"
  },
  "allowScripts": {
    "electron@42.5.1": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
